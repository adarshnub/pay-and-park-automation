# Copy to `.env.local` at this repository root and fill in values.
# Next.js and the ANPR worker (`services/anpr-worker`) both read this file.

# --- Supabase (Next.js + server APIs) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public origin for the app (metadata, redirects). Optional locally.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Preferred origin for copied staff share links (/s/...). Overrides NEXT_PUBLIC_APP_URL for links only.
# Use your production or custom domain, e.g. https://parking.example.com
# NEXT_PUBLIC_SHAREABLE_LINK_BASE_URL=https://parking.example.com

# --- Optional: OpenAI Vision OCR (Next.js API routes + ANPR worker) ---
# Strongly recommended on Vercel for OCR routes (shared-lot + dashboard check-in/out; avoids long local Tesseract).
# OPENAI_API_KEY=
# Optional: model id for org setting "OpenAI (…)" and /api/ocr/process (default gpt-4o-mini).
# OPENAI_OCR_MODEL=gpt-4o-mini

# Optional: Gemini Vision OCR via Google AI Studio (fallback when EasyOCR service doesn't return plate).
# Keys from AI Studio start with AIza... — see docs/parking-system-implementation.md#api-usage-for-plate-detection
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Optional: external EasyOCR service (PRIMARY OCR when configured).
# Deploy `services/anpr-worker/http_api.py` as a long-running container and point Next.js here.
# OCR_SERVICE_URL=http://your-easyocr-service:8000/ocr
# OCR_SERVICE_SECRET=replace-with-random-shared-secret

# Allow local Node Tesseract on Vercel for OCR routes (default: off). Needs Pro / high maxDuration if enabled.
# SHARED_LOT_ALLOW_SERVER_TESSERACT=true

# Optional: Supabase Edge OCR (Sharp in Next.js → Tesseract in Edge). Same secret in `supabase secrets set OCR_EDGE_SECRET`.
# Used by `/api/ocr/process` (dashboard Check In / Check Out) and `/api/shared-lot/process-image`.
# Next.js must also have NEXT_PUBLIC_SUPABASE_ANON_KEY so requests include Authorization: Bearer (Supabase gateway).
# SUPABASE_OCR_EDGE_URL=https://YOUR_PROJECT.supabase.co/functions/v1/ocr-tesseract
# OCR_EDGE_SECRET=

# --- ANPR worker only (optional; ignored by Next.js if unset) ---
# OCR_CONFIDENCE_THRESHOLD=70
# POLL_INTERVAL_SECONDS=3

# Legacy aliases (optional). Prefer the variables above.
# SUPABASE_URL=          # same as NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_SERVICE_KEY=  # same as SUPABASE_SERVICE_ROLE_KEY
